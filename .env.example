NEXT_PUBLIC_SITE_URL=https://palentrix.com
CMS_ADMIN_TOKEN=change-this-before-deploying
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/palentrix?retryWrites=true&w=majority
MONGODB_DB=palentrix
MONGODB_BLOG_COLLECTION=blog_posts

# ── Image uploads ────────────────────────────────────────────────────────────
# Leave all AWS_* vars unset to store uploads in public/uploads/blog/ locally.
# Set the four required vars to enable S3 (falls back to local if S3 fails).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Optional: custom endpoint for S3-compatible services (Cloudflare R2, MinIO…)
# AWS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Optional: public base URL for the bucket (CloudFront, R2 public domain, etc.)
# AWS_S3_PUBLIC_URL=https://cdn.yourdomain.com
